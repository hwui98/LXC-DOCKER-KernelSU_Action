# 内核源码地址（使用你自己 Fork 的带 SukiSU 版本）
KERNEL_SOURCE=https://github.com/hwui98/android_kernel_xiaomi_sm8250

# 内核源码分支（请确认你Fork的仓库默认分支是什么）
KERNEL_SOURCE_BRANCH=android16-aptusitu

# 内核编译配置（小米10）
KERNEL_CONFIG=vendor/umi_defconfig

# 内核打包名字
KERNEL_ZIP_NAME=umi_lxc_sukisu_20260630

# KVM
ENABLE_KVM=false

# 开启 LXC 支持（你的主要需求）
ENABLE_LXC_DOCKER=true

# 高端机推荐
KERNEL_IMAGE_NAME=Image.gz

# LLVM 参数
LLVM_CONFIG=y

SWITCH_PYTHON=false
NEED_DTBO=false

# KernelSU （因为你源码已自带SukiSU，可选择性开启）
ENABLE_KERNELSU=false
KERNELSU_TAG=main
